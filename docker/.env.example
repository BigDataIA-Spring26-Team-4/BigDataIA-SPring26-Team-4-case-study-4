# ============================================================================
# Docker Environment Configuration for PE Org-AI-R Platform
# ============================================================================
# Copy this file to docker/.env and fill with your actual values
# NEVER commit docker/.env to git (contains secrets)
# ============================================================================

# ── Snowflake (REQUIRED) ─────────────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=PE_ORG_AIR_DB
SNOWFLAKE_SCHEMA=PE_ORG_AIR_SCHEMA
SNOWFLAKE_WAREHOUSE=PE_ORG_AIR_WH
SNOWFLAKE_ROLE=ACCOUNTADMIN

# ── SEC EDGAR (REQUIRED) ─────────────────────────────────────────
SEC_EDGAR_EMAIL=your.email@example.com
SEC_EDGAR_COMPANY_NAME=PE-OrgAIR-Platform

# ── CS3 External API Keys (OPTIONAL) ─────────────────────────────
# PatentsView: https://patentsview.org/apis/purpose
PATENTSVIEW_API_KEY=
# Wextractor (Glassdoor): https://wextractor.com
WEXTRACTOR_TOKEN=
# sec-api.io (Board data): https://sec-api.io
SEC_API_KEY=
# GNews (News/PR): https://gnews.io
GNEWS_API_KEY=

# ── AWS S3 (OPTIONAL) ────────────────────────────────────────────
S3_ENABLED=false

# ── Application ───────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
